# Copy to .env and fill in. .env is gitignored.

# Accounts to pull, comma- or newline-separated. Leading "@" is optional.
# Multi-line form: wrap in double quotes (dotenv supports it).
# XTRICATE_ACCOUNTS=paulg,karpathy,simonw
# XTRICATE_ACCOUNTS="
# paulg
# karpathy
# simonw
# "
XTRICATE_ACCOUNTS=

# Bluesky handles to pull (optional). Same comma- or newline-separated format.
# Use the full handle, e.g. "paulg.bsky.social" or a custom-domain handle.
XTRICATE_BLUESKY_ACCOUNTS=

# twitterapi.io — dashboard -> API Key (https://twitterapi.io)
TWITTERAPI_IO_KEY=

# Anthropic — console.anthropic.com -> Settings -> API Keys (starts with sk-ant-)
ANTHROPIC_API_KEY=

# Where the weekly digest is delivered (only needed for live email).
XTRICATE_RECIPIENT=

# Gmail sender (only needed for live email, not for --dry-run)
# Generate an App Password: myaccount.google.com -> Security -> App passwords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
